# ── Active LLM selection ─────────────────────────────────────────────
# PROVIDER selects which API_BASE + API_KEY are used at runtime.
# Valid values: nvidia | tencent | cloudflare | mimo
# MODEL must be a model ID supported by the chosen provider.
PROVIDER=nvidia
MODEL=moonshotai/kimi-k2.5

# ── Provider: NVIDIA NIM (OpenAI-compatible) ─────────────────────────
# Models: moonshotai/kimi-k2.5, qwen/qwen3.5-397b-a17b, deepseek-ai/deepseek-v4-pro, ...
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1
NVIDIA_API_KEY=nvapi-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Provider: Tencent TokenHub MaaS (OpenAI-compatible) ──────────────
# Models: kimi-k2.6, deepseek-v4-pro, ...
TENCENT_API_BASE=https://tokenhub.tencentmaas.com/v1
TENCENT_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Provider: Cloudflare Workers AI ──────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID
CLOUDFLARE_API_TOKEN=cfut_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Provider: MIMO (Xiaomi, OpenAI-compatible) ────────────────────────
MIMO_API_BASE=https://token-plan-sgp.xiaomimimo.com/v1
MIMO_API_KEY=***

# Optional: DeepSeek API (if used directly)
DEEPSEEK_API_TOKEN=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
